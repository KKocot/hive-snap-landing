---
// Final CTA section
---

<section
  class="relative py-16 md:py-24 px-4 md:px-6"
  aria-labelledby="cta-heading"
>
  <div
    class="absolute inset-0 pointer-events-none -z-1"
    style="background: radial-gradient(ellipse at 50% 50%, rgba(227,19,55,0.10) 0%, transparent 60%);"
    aria-hidden="true"
  >
  </div>

  <div class="max-w-[720px] mx-auto text-center">
    <h2
      id="cta-heading"
      class="animate-on-scroll text-[2rem] md:text-[2.5rem] font-bold text-white mb-6"
    >
      Ready to connect Hive to MetaMask?
    </h2>
    <p class="animate-on-scroll text-lg text-text-secondary mb-10">
      Join the Hive ecosystem with secure, seamless MetaMask integration.
    </p>
    <div class="animate-on-scroll">
      <a
        href="https://snaps.metamask.io/snap/npm/@hiveio/metamask-snap/"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-primary inline-flex items-center justify-center gap-2 px-10 py-4 text-lg font-medium min-h-[48px]"
      >
        <!-- MetaMask fox icon -->
        <svg
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          aria-hidden="true"
        >
          <path
            d="M21.3 2L13.1 8.1l1.5-3.6L21.3 2z"
            fill="#E2761B"
            stroke="#E2761B"
            stroke-width="0.3"></path>
          <path
            d="M2.7 2l8.1 6.2-1.4-3.7L2.7 2zM18.4 17.2l-2.2 3.3 4.7 1.3 1.3-4.5-3.8-.1zM1.8 17.3l1.3 4.5 4.7-1.3-2.2-3.3-3.8.1z"
            fill="#E4761B"
            stroke="#E4761B"
            stroke-width="0.3"></path>
          <path
            d="M7.5 10.5L6.3 12.3l4.7.2-.2-5-3.3 3zM16.5 10.5l-3.4-3.1-.1 5.1 4.7-.2-1.2-1.8zM7.8 20.5l2.8-1.4-2.4-1.9-.4 3.3zM13.4 19.1l2.8 1.4-.4-3.3-2.4 1.9z"
            fill="#E4761B"
            stroke="#E4761B"
            stroke-width="0.3"></path>
        </svg>
        Install Snap
      </a>
    </div>
  </div>
</section>
