---
const currentYear = new Date().getFullYear();
---

<footer class="tmux-status" role="contentinfo">
  <div class="tmux-status__bar">
    <span class="tmux-status__segment"
      ><a
        href="https://github.com/nicetransition/hive-wallet-snap"
        class="tmux-status__link"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Hive Wallet Snap — source on GitHub"
        >[hive wallet snap]</a
      ></span
    ><span class="tmux-status__sep" aria-hidden="true">│</span><span
      class="tmux-status__segment"
      >&copy; {currentYear} BardDev</span
    ><span class="tmux-status__sep" aria-hidden="true">│</span><a
      href="https://github.com/nicetransition/hive-wallet-snap/blob/main/LICENSE"
      target="_blank"
      rel="noopener noreferrer"
      class="tmux-status__link"
      aria-label="MIT License — opens in new tab"
      >MIT License</a
    ><span class="tmux-status__sep" aria-hidden="true">│</span><span
      class="tmux-status__segment"
      >built for <span class="tmux-status__hive">hive</span></span
    ><span class="tmux-status__sep" aria-hidden="true">│</span><span
      class="tmux-status__dot"
      aria-label="MetaMask Snap Active">●</span
    >
  </div>
</footer>

<style>
  .tmux-status {
    background-color: var(--color-bg-surface);
    border-top: 1px solid var(--border-subtle);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    color: var(--color-text-muted);
    line-height: 1;
  }

  .tmux-status__bar {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0;
    padding: 0.5rem 1rem;
    min-height: 2rem;
  }

  .tmux-status__segment {
    display: inline-flex;
    align-items: center;
    white-space: nowrap;
  }

  .tmux-status__sep {
    color: var(--color-text-subtle);
    padding-inline: 0.5rem;
    user-select: none;
  }

  .tmux-status__link {
    color: var(--color-text-muted);
    text-decoration: none;
    white-space: nowrap;
    transition:
      color var(--duration-fast) var(--ease-out),
      text-shadow var(--duration-fast) var(--ease-out);
  }

  .tmux-status__link:hover,
  .tmux-status__link:focus-visible {
    color: var(--color-accent-hive-hover);
    text-shadow: var(--glow-intensity) var(--glow-color);
  }

  .tmux-status__link:focus-visible {
    outline: 2px solid var(--color-accent-hive);
    outline-offset: 2px;
    border-radius: 2px;
  }

  .tmux-status__hive {
    color: var(--color-hive-text);
    font-weight: 600;
  }

  .tmux-status__dot {
    color: var(--color-success);
    font-size: 0.5rem;
    line-height: 1;
    animation: pulse-dot 2s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%, 100% {
      opacity: 1;
    }
    50% {
      opacity: 0.4;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .tmux-status__dot {
      animation: none;
    }
  }

  @media (max-width: 40rem) {
    .tmux-status__bar {
      padding: 0.5rem 0.75rem;
      gap: 0.25rem 0;
      justify-content: center;
    }
  }
</style>
