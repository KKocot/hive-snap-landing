---
---

<footer class="tmux-status" role="contentinfo">
  <div class="tmux-status__bar">
    <span class="tmux-status__segment"
      ><a
        href="https://gitlab.syncad.com/hive/metamask-snap"
        class="tmux-status__link"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Hive Wallet Snap — source on GitLab"
        >[hive wallet snap]</a
      ></span
    ><span class="tmux-status__sep" aria-hidden="true">│</span><a
      href="https://gitlab.syncad.com/hive/metamask-snap/-/blob/main/LICENSE.md?ref_type=heads"
      target="_blank"
      rel="noopener noreferrer"
      class="tmux-status__link"
      aria-label="MIT License — opens in new tab"
      >MIT License</a
    ><span class="tmux-status__sep" aria-hidden="true">│</span><a
      href="https://hive.io"
      target="_blank"
      rel="noopener noreferrer"
      class="tmux-status__link"
      >Hive</a
    ><span class="tmux-status__sep" aria-hidden="true">│</span><a
      href="https://auth.openhive.network/"
      target="_blank"
      rel="noopener noreferrer"
      class="tmux-status__link"
      >Wallet</a
    ><span class="tmux-status__sep" aria-hidden="true">│</span><a
      href="https://www.npmjs.com/package/@hiveio/metamask-snap"
      target="_blank"
      rel="noopener noreferrer"
      class="tmux-status__link"
      >npm</a
    ><span class="tmux-status__sep" aria-hidden="true">│</span><a
      href="https://blockchainwares.com.pl/"
      target="_blank"
      rel="noopener noreferrer"
      class="tmux-status__link"
      >Blockchain Wares</a
    ><span class="tmux-status__sep" aria-hidden="true">│</span><a
      href="https://tools.openhive.network"
      target="_blank"
      rel="noopener noreferrer"
      class="tmux-status__link"
      >Hive Tools</a
    >
  </div>
</footer>

<style>
  .tmux-status {
    background-color: var(--color-bg-surface);
    border-top: 1px solid var(--border-subtle);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    color: var(--color-text-muted);
    line-height: 1;
  }

  .tmux-status__bar {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0;
    padding: 0.5rem 1rem;
    min-height: 2rem;
  }

  .tmux-status__segment {
    display: inline-flex;
    align-items: center;
    white-space: nowrap;
  }

  .tmux-status__sep {
    color: var(--color-text-subtle);
    padding-inline: 0.5rem;
    user-select: none;
  }

  .tmux-status__link {
    color: var(--color-text-muted);
    text-decoration: none;
    white-space: nowrap;
    transition:
      color var(--duration-fast) var(--ease-out),
      text-shadow var(--duration-fast) var(--ease-out);
  }

  .tmux-status__link:hover,
  .tmux-status__link:focus-visible {
    color: var(--color-accent-hive-hover);
    text-shadow: var(--glow-intensity) var(--glow-color);
  }

  .tmux-status__link:focus-visible {
    outline: 2px solid var(--color-accent-hive);
    outline-offset: 2px;
    border-radius: 2px;
  }

  @media (max-width: 40rem) {
    .tmux-status__bar {
      padding: 0.5rem 0.75rem;
      gap: 0.25rem 0;
      justify-content: center;
    }
  }
</style>
