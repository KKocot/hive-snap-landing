---
// Footer with logo, link columns, and copyright
---

<footer
  class="pt-16 pb-8 px-4 md:px-6 border-t"
  style="border-color: var(--border-subtle);"
  aria-label="Site footer"
>
  <div class="max-w-[1200px] mx-auto">
    <!-- Top row -->
    <div class="flex flex-col md:flex-row justify-between items-start gap-8">
      <!-- Left: logo + tagline -->
      <div>
        <a
          href="/"
          class="flex items-center gap-2"
          aria-label="Hive Wallet home"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 50 50"
            aria-hidden="true"
            role="presentation"
          >
            <g transform="matrix(0.22 0 0 0.22 25 25)"
              ><g
                ><g transform="matrix(1 0 0 1 9.98 0)">
                  <path
                    fill="#e31337"
                    transform="translate(-120, -95)"
                    d="M 157.27 107.26 C 157.6 107.29 157.89 107.47 158.05 107.76 C 158.21 108.04 158.23 108.38 158.09 108.68 L 111.34 189.53 C 111.16 189.81 110.85 189.99 110.52 190 L 81.94 190 C 81.6 190 81.29 189.82 81.12 189.53 C 80.95 189.23 80.96 188.87 81.13 188.58 L 127.88 107.73 C 128.05 107.44 128.36 107.26 128.69 107.26 Z M 129.48 84.09 C 129.15 84.08 128.84 83.9 128.66 83.62 L 81.13 1.42 C 80.96 1.13 80.95 0.77 81.12 0.47 C 81.29 0.18 81.6 0 81.94 0 L 110.52 0 C 110.85 0.01 111.16 0.19 111.34 0.47 L 158.87 82.67 C 159.04 82.96 159.05 83.32 158.88 83.62 C 158.71 83.91 158.4 84.09 158.06 84.09 Z"
                    stroke-linecap="round"></path>
                </g><g>
                  <path
                    fill="#e31337"
                    transform="translate(-110, -95)"
                    d="M 135.13 1.42 C 134.95 1.12 134.95 0.74 135.14 0.45 C 135.32 0.15 135.65 -0.02 136 0 L 164.62 0 C 164.95 0 165.26 0.18 165.43 0.47 L 219.92 94.53 C 220.09 94.82 220.09 95.18 219.92 95.47 L 165.43 189.53 C 165.26 189.82 164.95 190 164.62 190 L 136 190 C 135.66 190 135.34 189.82 135.17 189.53 C 135 189.24 135.01 188.87 135.18 188.58 L 189.34 95 Z M 111.87 94.52 C 112.05 94.83 112.05 95.21 111.87 95.52 L 57.13 189.53 C 56.94 189.8 56.63 189.96 56.31 189.96 C 55.98 189.96 55.67 189.8 55.48 189.53 L 0.13 95.48 C -0.05 95.17 -0.05 94.79 0.13 94.48 L 54.87 0.47 C 55.06 0.2 55.37 0.04 55.7 0.04 C 56.02 0.04 56.33 0.2 56.52 0.47 Z"
                    stroke-linecap="round"></path>
                </g></g
              ></g
            >
          </svg>
          <span class="font-semibold text-sm text-white">Hive Wallet</span>
        </a>
        <p class="mt-2 text-sm text-text-muted">
          MetaMask Snap for Hive blockchain
        </p>
      </div>

      <!-- Right: link columns -->
      <nav
        class="flex flex-col sm:flex-row gap-8 sm:gap-12"
        aria-label="Footer navigation"
      >
        <div>
          <h3
            class="text-xs uppercase tracking-[0.1em] text-white font-semibold mb-3"
          >
            Resources
          </h3>
          <ul class="flex flex-col gap-2">
            <li>
              <a
                href="https://gitlab.syncad.com/hive/metamask-snap"
                target="_blank"
                rel="noopener noreferrer"
                class="text-sm text-text-secondary hover:text-white transition-colors duration-150"
                >Documentation</a
              >
            </li>
            <li>
              <a
                href="https://www.npmjs.com/package/@hiveio/metamask-snap"
                target="_blank"
                rel="noopener noreferrer"
                class="text-sm text-text-secondary hover:text-white transition-colors duration-150"
                >npm Package</a
              >
            </li>
            <li>
              <a
                href="https://gitlab.syncad.com/hive/metamask-snap"
                target="_blank"
                rel="noopener noreferrer"
                class="text-sm text-text-secondary hover:text-white transition-colors duration-150"
                >Source Code</a
              >
            </li>
          </ul>
        </div>
        <div>
          <h3
            class="text-xs uppercase tracking-[0.1em] text-white font-semibold mb-3"
          >
            Community
          </h3>
          <ul class="flex flex-col gap-2">
            <li>
              <a
                href="https://hive.blog"
                target="_blank"
                rel="noopener noreferrer"
                class="text-sm text-text-secondary hover:text-white transition-colors duration-150"
                >Hive Blog</a
              >
            </li>
            <li>
              <a
                href="https://peakd.com"
                target="_blank"
                rel="noopener noreferrer"
                class="text-sm text-text-secondary hover:text-white transition-colors duration-150"
                >PeakD</a
              >
            </li>
            <li>
              <a
                href="https://gitlab.syncad.com/hive/metamask-snap/-/issues"
                target="_blank"
                rel="noopener noreferrer"
                class="text-sm text-text-secondary hover:text-white transition-colors duration-150"
                >GitLab Issues</a
              >
            </li>
          </ul>
        </div>
      </nav>
    </div>

    <!-- Bottom bar -->
    <div
      class="flex flex-col sm:flex-row justify-between items-center mt-12 pt-6 border-t gap-2"
      style="border-color: var(--border-subtle);"
    >
      <p class="text-xs text-text-muted">MIT License</p>
      <p class="text-xs text-text-muted">
        &copy; 2024&ndash;2026 Hive Community
      </p>
    </div>
  </div>
</footer>
