---
// How It Works — vertical stacked steps
---

<section
  id="how-it-works"
  class="min-h-screen flex flex-col justify-center py-16 md:py-20 lg:py-24 px-4 md:px-6 bg-bg-card"
  aria-labelledby="how-heading"
>
  <div class="max-w-[900px] mx-auto w-full">
    <h2
      id="how-heading"
      class="text-[2rem] md:text-[2.5rem] font-bold text-white text-center mb-16 animate-on-scroll"
    >
      Get started in three steps
    </h2>

    <div class="flex flex-col">
      <!-- Step 1 -->
      <div
        class="animate-on-scroll flex items-start gap-5 md:gap-8 py-8 border-b"
        style="border-color: var(--border-subtle);"
      >
        <span
          class="font-mono text-[3rem] md:text-[5rem] leading-none font-bold select-none shrink-0"
          style="color: var(--color-accent-hive); opacity: 0.12;"
          aria-hidden="true">01</span
        >
        <div class="pt-1 md:pt-3">
          <h3 class="text-xl font-semibold text-white mb-2">
            Install
          </h3>
          <p class="text-sm text-text-secondary leading-relaxed max-w-[32rem]">
            Install from the official MetaMask Snap directory or connect via the demo site.
          </p>
        </div>
      </div>

      <!-- Step 2 -->
      <div
        class="animate-on-scroll flex items-start gap-5 md:gap-8 py-8 border-b"
        style="border-color: var(--border-subtle);"
      >
        <span
          class="font-mono text-[3rem] md:text-[5rem] leading-none font-bold select-none shrink-0"
          style="color: var(--color-accent-hive); opacity: 0.12;"
          aria-hidden="true">02</span
        >
        <div class="pt-1 md:pt-3">
          <h3 class="text-xl font-semibold text-white mb-2">
            Approve
          </h3>
          <p class="text-sm text-text-secondary leading-relaxed max-w-[32rem]">
            Approve BIP44 key derivation, RPC communication, dialog, and WebAssembly permissions.
          </p>
        </div>
      </div>

      <!-- Step 3 -->
      <div class="animate-on-scroll flex items-start gap-5 md:gap-8 py-8">
        <span
          class="font-mono text-[3rem] md:text-[5rem] leading-none font-bold select-none shrink-0"
          style="color: var(--color-accent-hive); opacity: 0.12;"
          aria-hidden="true">03</span
        >
        <div class="pt-1 md:pt-3">
          <h3 class="text-xl font-semibold text-white mb-2">
            Sign
          </h3>
          <p class="text-sm text-text-secondary leading-relaxed max-w-[32rem]">
            Sign Hive transactions, encrypt and decrypt buffers, and retrieve your public keys.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
