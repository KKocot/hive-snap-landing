---
// How It Works — 3 steps with connecting line
---

<section
  id="how-it-works"
  class="min-h-screen flex flex-col justify-center py-16 md:py-20 lg:py-24 px-4 md:px-6 bg-bg-card"
  aria-labelledby="how-heading"
>
  <div class="max-w-[900px] mx-auto">
    <h2
      id="how-heading"
      class="text-[2rem] md:text-[2.5rem] font-bold text-white text-center mb-16 animate-on-scroll"
    >
      Get started in three steps
    </h2>

    <div class="relative flex flex-col md:flex-row gap-8 md:gap-4">
      <!-- Connecting line (desktop only) -->
      <div class="steps-line hidden md:block" aria-hidden="true"></div>

      <!-- Step 1 -->
      <div class="flex-1 text-center relative">
        <div
          class="animate-scale-in w-12 h-12 rounded-full flex items-center justify-center mx-auto mb-6 relative z-10 text-white font-bold text-lg"
          style="background: var(--gradient-hive);"
        >
          1
        </div>
        <h3 class="animate-on-scroll text-xl font-semibold text-white mb-2">
          Install
        </h3>
        <p
          class="animate-on-scroll text-sm text-text-secondary max-w-[240px] mx-auto"
        >
          Install from the official MetaMask Snap directory or connect via the demo site.
        </p>
      </div>

      <!-- Step 2 -->
      <div class="flex-1 text-center relative">
        <div
          class="animate-scale-in w-12 h-12 rounded-full flex items-center justify-center mx-auto mb-6 relative z-10 text-white font-bold text-lg"
          style="background: var(--gradient-hive); transition-delay: 150ms;"
        >
          2
        </div>
        <h3 class="animate-on-scroll text-xl font-semibold text-white mb-2">
          Approve
        </h3>
        <p
          class="animate-on-scroll text-sm text-text-secondary max-w-[240px] mx-auto"
        >
          Approve BIP44 key derivation, RPC communication, dialog, and WebAssembly permissions.
        </p>
      </div>

      <!-- Step 3 -->
      <div class="flex-1 text-center relative">
        <div
          class="animate-scale-in w-12 h-12 rounded-full flex items-center justify-center mx-auto mb-6 relative z-10 text-white font-bold text-lg"
          style="background: var(--gradient-hive); transition-delay: 300ms;"
        >
          3
        </div>
        <h3 class="animate-on-scroll text-xl font-semibold text-white mb-2">
          Sign
        </h3>
        <p
          class="animate-on-scroll text-sm text-text-secondary max-w-[240px] mx-auto"
        >
          Sign Hive transactions, encrypt and decrypt buffers, and retrieve your public keys.
        </p>
      </div>
    </div>
  </div>
</section>
