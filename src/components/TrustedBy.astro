          fill="#233447"></path>
        <path
          d="M12.9 34.2l.6-5.5-4.2.1 3.6 5.4zM26.5 28.7l.6 5.5 3.6-5.4-4.2-.1zM29.5 20.5l-7.8.3.7 4 1.1-2.4 2.8 1.3 3.2-3.2zM13.4 23.7l2.8-1.3 1.1 2.4.7-4-7.8-.3 3.2 3.2z"
          fill="#CD6116"></path>
        <path
