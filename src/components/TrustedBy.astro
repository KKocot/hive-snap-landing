          fill="#E4751F"></path>
        <path
          d="M22.4 24.8l-.9 4.5.6.5 4.1-3.2.2-3.4-4 1.6zM13.4 23.2l.1 3.4 4.1 3.2.6-.5-.9-4.5-3.9-1.6z"
          fill="#F6851B"></path>
