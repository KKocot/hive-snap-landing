          fill="#763D16"></path>
      </svg>
    </div>
    <!-- npm logo -->
    <div class="logo-item animate-on-scroll" role="img" aria-label="npm">
      <svg
        width="48"
        height="20"
        viewBox="0 0 48 20"
        fill="none"
        aria-hidden="true"
      >
        <rect x="0" y="0" width="48" height="20" rx="3" fill="#CB3837"
        ></rect>
        <text
          x="24"
          y="15"
          text-anchor="middle"
          fill="white"
          font-family="Inter, sans-serif"
          font-weight="700"
          font-size="13">npm</text
        >
      </svg>
    </div>
    <!-- GitLab logo -->
    <div class="logo-item animate-on-scroll" role="img" aria-label="GitLab">
      <svg
        width="40"
        height="40"
        viewBox="0 0 40 40"
        fill="none"
        aria-hidden="true"
      >
        <path d="M20 36.7L26.5 16.7H13.5L20 36.7z" fill="#E24329"
        ></path>
        <path d="M20 36.7L13.5 16.7H3.2L20 36.7z" fill="#FC6D26"
        ></path>
        <path
          d="M3.2 16.7L1.1 23.3c-.2.6 0 1.2.5 1.6L20 36.7 3.2 16.7z"
          fill="#FCA326"></path>
        <path
          d="M3.2 16.7h10.3L9.1 3.8c-.2-.7-1.2-.7-1.5 0L3.2 16.7z"
          fill="#E24329"></path>
        <path d="M20 36.7l6.5-20h10.3L20 36.7z" fill="#FC6D26"
        ></path>
        <path
          d="M36.8 16.7l2.1 6.6c.2.6 0 1.2-.5 1.6L20 36.7l16.8-20z"
          fill="#FCA326"></path>
        <path
          d="M36.8 16.7H26.5l4.3-12.9c.2-.7 1.2-.7 1.5 0l4.5 12.9z"
          fill="#E24329"></path>
      </svg>
    </div>
  </div>
</section>
