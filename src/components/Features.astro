---
// Features grid — 2x2 glass cards
---

<section
  id="features"
  class="py-16 md:py-20 lg:py-24 px-4 md:px-6"
  aria-labelledby="features-heading"
>
  <div class="max-w-[900px] mx-auto">
    <div class="text-center mb-12 animate-on-scroll">
      <h2
        id="features-heading"
        class="text-[2rem] md:text-[2.5rem] font-bold text-white mb-4"
      >
        Built for security. Designed for simplicity.
      </h2>
      <p class="text-lg text-text-secondary">
        Four core capabilities, zero compromises.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6" data-stagger="true">
      <!-- Feature 1: Sign Transactions -->
      <article class="glass-card p-8 animate-on-scroll">
        <div
          class="w-12 h-12 flex items-center justify-center rounded-xl mb-5"
          style="background: rgba(227,19,55,0.08);"
        >
          <svg
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="#e31337"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M12 20h9"></path>
            <path
              d="M16.376 3.622a1 1 0 0 1 3.002 3.002L7.368 18.635a2 2 0 0 1-.855.506l-2.872.838a.5.5 0 0 1-.62-.62l.838-2.872a2 2 0 0 1 .506-.854z"
            ></path>
          </svg>
        </div>
        <h3 class="text-xl font-semibold text-white mb-2">Sign Transactions</h3>
        <p class="text-sm text-text-secondary leading-relaxed">
          Authorize Hive transactions with user confirmation dialogs.
          Multi-operation support with clear previews.
        </p>
      </article>

      <!-- Feature 2: Derive Keys -->
      <article class="glass-card p-8 animate-on-scroll">
        <div
          class="w-12 h-12 flex items-center justify-center rounded-xl mb-5"
          style="background: rgba(227,19,55,0.08);"
        >
          <svg
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="#e31337"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path
              d="M2.586 17.414A2 2 0 0 0 2 18.828V21a1 1 0 0 0 1 1h3a1 1 0 0 0 1-1v-1a1 1 0 0 1 1-1h1a1 1 0 0 0 1-1v-1a1 1 0 0 1 1-1h.172a2 2 0 0 0 1.414-.586l.814-.814a6.5 6.5 0 1 0-4-4z"
            ></path>
            <circle cx="16.5" cy="7.5" r=".5" fill="#e31337"></circle>
          </svg>
        </div>
        <h3 class="text-xl font-semibold text-white mb-2">Derive Keys</h3>
        <p class="text-sm text-text-secondary leading-relaxed">
          BIP44 key derivation (m/44'/3054') for owner, active, posting, and
          memo keys. On-demand, never stored.
        </p>
      </article>

      <!-- Feature 3: Encrypt & Decrypt -->
      <article class="glass-card p-8 animate-on-scroll">
        <div
          class="w-12 h-12 flex items-center justify-center rounded-xl mb-5"
          style="background: rgba(227,19,55,0.08);"
        >
          <svg
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="#e31337"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path
              d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"
            ></path>
            <path d="m9 12 2 2 4-4"></path>
          </svg>
        </div>
        <h3 class="text-xl font-semibold text-white mb-2">
          Encrypt & Decrypt
        </h3>
        <p class="text-sm text-text-secondary leading-relaxed">
          End-to-end buffer encryption using memo keys. SHA-256 digest signing
          for data integrity.
        </p>
      </article>

      <!-- Feature 4: Zero Key Storage -->
      <article class="glass-card p-8 animate-on-scroll">
        <div
          class="w-12 h-12 flex items-center justify-center rounded-xl mb-5"
          style="background: rgba(227,19,55,0.08);"
        >
          <svg
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="#e31337"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path
              d="M10.733 5.076a10.744 10.744 0 0 1 11.205 6.575 1 1 0 0 1 0 .696 10.747 10.747 0 0 1-1.444 2.49"
            ></path>
            <path d="M14.084 14.158a3 3 0 0 1-4.242-4.242"></path>
            <path
              d="M17.479 17.499a10.75 10.75 0 0 1-15.417-5.151 1 1 0 0 1 0-.696 10.75 10.75 0 0 1 4.446-5.143"
            ></path>
            <path d="m2 2 20 20"></path>
          </svg>
        </div>
        <h3 class="text-xl font-semibold text-white mb-2">Zero Key Storage</h3>
        <p class="text-sm text-text-secondary leading-relaxed">
          Private keys derived, used, and immediately cleared. WASM sandbox
          isolation. No persistence.
        </p>
      </article>
    </div>
  </div>
</section>
