            </g></g
          ></g
        >
      </svg>
      <span class="font-semibold text-sm text-white">MetaMask Snap</span>
    </a>

    <!-- Desktop nav links -->
    <div class="hidden md:flex items-center gap-6">
      <a
        href="#features"
        class="text-sm text-text-secondary hover:text-white transition-colors duration-150"
        >Features</a
      >
      <a
        href="#security"
        class="text-sm text-text-secondary hover:text-white transition-colors duration-150"
        >Security</a
      >
      <a
        href="#developers"
        class="text-sm text-text-secondary hover:text-white transition-colors duration-150"
        >Developers</a
      >
      <div class="w-px h-5 bg-white/10"></div>
      <div class="flex items-center gap-4">
        <a
          href="https://gitlab.syncad.com/hive/metamask-snap"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="GitLab Repository"
          class="text-text-secondary hover:text-accent-hive transition-colors duration-150"
        >
          <svg class="size-6" viewBox="0 0 32 32" fill="currentColor" aria-hidden="true"><path d="M16 30.4L21.3 14.1H10.7L16 30.4Z"/><path d="M16 30.4L10.7 14.1H2.4L16 30.4Z" opacity="0.7"/><path d="M2.4 14.1L0.5 20.1C0.3 20.7 0.5 21.4 1 21.8L16 30.4L2.4 14.1Z" opacity="0.5"/><path d="M2.4 14.1H10.7L7.4 3.9C7.2 3.3 6.4 3.3 6.2 3.9L2.4 14.1Z"/><path d="M16 30.4L21.3 14.1H29.6L16 30.4Z" opacity="0.7"/><path d="M29.6 14.1L31.5 20.1C31.7 20.7 31.5 21.4 31 21.8L16 30.4L29.6 14.1Z" opacity="0.5"/><path d="M29.6 14.1H21.3L24.6 3.9C24.8 3.3 25.6 3.3 25.8 3.9L29.6 14.1Z"/></svg>
        </a>
        <a
          href="https://www.npmjs.com/package/@hiveio/metamask-snap"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="npm Package"
          class="text-text-secondary hover:text-accent-hive transition-colors duration-150"
        >
          <svg class="size-6" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M0 7.334v8h6.666v1.332H12v-1.332h12v-8H0zm6.666 6.664H5.334v-4H3.999v4H1.335V8.667h5.331v5.331zm4 0v1.336H8.001V8.667h5.334v5.331h-2.669zm12-.002h-1.33v-4h-1.336v4h-1.335v-4h-1.33v4h-2.671V8.667h8.002v5.329z" />
          </svg>
        </a>
        <a
          href="https://www.youtube.com/watch?v=zKT1GXO6G-0"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="YouTube Demo"
          class="text-text-secondary hover:text-accent-hive transition-colors duration-150"
        >
          <svg class="size-6" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12z"/>
          </svg>
        </a>
      </div>
    </div>

    <!-- Mobile hamburger -->
    <button
      class="md:hidden p-2 text-white"
      aria-expanded="false"
      aria-controls="mobile-menu"
      id="hamburger-btn"
    >
      <span class="sr-only">Open menu</span>
      <svg
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
    </button>
  </div>

  <!-- Mobile menu overlay -->
  <div
    id="mobile-menu"
    class="mobile-menu md:hidden fixed inset-0 top-16 bg-bg-primary z-40"
    role="dialog"
    aria-label="Mobile navigation"
    hidden
  >
    <div class="flex flex-col items-center gap-6 pt-12 px-4">
      <a
        href="#features"
        class="text-lg text-text-secondary hover:text-white transition-colors duration-150 mobile-nav-link"
        >Features</a
      >
      <a
        href="#security"
        class="text-lg text-text-secondary hover:text-white transition-colors duration-150 mobile-nav-link"
        >Security</a
      >
      <a
        href="#developers"
        class="text-lg text-text-secondary hover:text-white transition-colors duration-150 mobile-nav-link"
        >Developers</a
      >
      <div class="flex items-center justify-center gap-6 mt-2">
        <a
          href="https://gitlab.syncad.com/hive/metamask-snap"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="GitLab Repository"
          class="text-text-secondary hover:text-accent-hive transition-colors duration-150"
        >
          <svg class="size-7" viewBox="0 0 32 32" fill="currentColor" aria-hidden="true"><path d="M16 30.4L21.3 14.1H10.7L16 30.4Z"/><path d="M16 30.4L10.7 14.1H2.4L16 30.4Z" opacity="0.7"/><path d="M2.4 14.1L0.5 20.1C0.3 20.7 0.5 21.4 1 21.8L16 30.4L2.4 14.1Z" opacity="0.5"/><path d="M2.4 14.1H10.7L7.4 3.9C7.2 3.3 6.4 3.3 6.2 3.9L2.4 14.1Z"/><path d="M16 30.4L21.3 14.1H29.6L16 30.4Z" opacity="0.7"/><path d="M29.6 14.1L31.5 20.1C31.7 20.7 31.5 21.4 31 21.8L16 30.4L29.6 14.1Z" opacity="0.5"/><path d="M29.6 14.1H21.3L24.6 3.9C24.8 3.3 25.6 3.3 25.8 3.9L29.6 14.1Z"/></svg>
        </a>
        <a
          href="https://www.npmjs.com/package/@hiveio/metamask-snap"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="npm Package"
          class="text-text-secondary hover:text-accent-hive transition-colors duration-150"
        >
          <svg class="size-7" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M0 7.334v8h6.666v1.332H12v-1.332h12v-8H0zm6.666 6.664H5.334v-4H3.999v4H1.335V8.667h5.331v5.331zm4 0v1.336H8.001V8.667h5.334v5.331h-2.669zm12-.002h-1.33v-4h-1.336v4h-1.335v-4h-1.33v4h-2.671V8.667h8.002v5.329z" />
          </svg>
        </a>
        <a
          href="https://www.youtube.com/watch?v=zKT1GXO6G-0"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="YouTube Demo"
          class="text-text-secondary hover:text-accent-hive transition-colors duration-150"
        >
          <svg class="size-7" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12z"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</nav>

<script>
  // Navbar scroll behavior
  const navbar = document.querySelector(".navbar");
  const scrollThreshold = 50;

  const sentinel = document.createElement("div");
  sentinel.style.cssText =
    "position:absolute;top:0;left:0;width:1px;height:" +
    scrollThreshold +
    "px;pointer-events:none;";
  document.body.prepend(sentinel);

  const navObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          navbar?.classList.remove("scrolled");
        } else {
          navbar?.classList.add("scrolled");
        }
      });
    },
    { threshold: 0 },
  );
  navObserver.observe(sentinel);

  // Mobile menu
  const hamburgerBtn = document.getElementById("hamburger-btn");
  const mobileMenu = document.getElementById("mobile-menu");
  const mobileNavLinks = document.querySelectorAll(".mobile-nav-link");

  function toggleMobileMenu(): void {
    const isOpen = hamburgerBtn?.getAttribute("aria-expanded") === "true";
    hamburgerBtn?.setAttribute("aria-expanded", String(!isOpen));
    if (isOpen) {
      mobileMenu?.classList.remove("open");
      setTimeout(() => {
        if (mobileMenu) mobileMenu.hidden = true;
      }, 300);
    } else {
      if (mobileMenu) mobileMenu.hidden = false;
      // Force reflow for transition
      mobileMenu?.offsetHeight;
      mobileMenu?.classList.add("open");
    }
  }

  hamburgerBtn?.addEventListener("click", toggleMobileMenu);

  mobileNavLinks.forEach((link) => {
    link.addEventListener("click", () => {
      hamburgerBtn?.setAttribute("aria-expanded", "false");
      mobileMenu?.classList.remove("open");
      setTimeout(() => {
        if (mobileMenu) mobileMenu.hidden = true;
      }, 300);
    });
  });

  // Smooth scroll for anchor links
  document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
    anchor.addEventListener("click", (e) => {
      const targetId = (e.currentTarget as HTMLAnchorElement).getAttribute(
        "href",
      );
      if (targetId === "#") return;
      const target = document.querySelector(targetId!);
      if (target) {
        e.preventDefault();
        target.scrollIntoView({ behavior: "smooth", block: "start" });
      }
    });
  });
</script>
