            </g><g>
              <path
                fill="#e31337"
                transform="translate(-110, -95)"
                d="M 135.13 1.42 C 134.95 1.12 134.95 0.74 135.14 0.45 C 135.32 0.15 135.65 -0.02 136 0 L 164.62 0 C 164.95 0 165.26 0.18 165.43 0.47 L 219.92 94.53 C 220.09 94.82 220.09 95.18 219.92 95.47 L 165.43 189.53 C 165.26 189.82 164.95 190 164.62 190 L 136 190 C 135.66 190 135.34 189.82 135.17 189.53 C 135 189.24 135.01 188.87 135.18 188.58 L 189.34 95 Z M 111.87 94.52 C 112.05 94.83 112.05 95.21 111.87 95.52 L 57.13 189.53 C 56.94 189.8 56.63 189.96 56.31 189.96 C 55.98 189.96 55.67 189.8 55.48 189.53 L 0.13 95.48 C -0.05 95.17 -0.05 94.79 0.13 94.48 L 54.87 0.47 C 55.06 0.2 55.37 0.04 55.7 0.04 C 56.02 0.04 56.33 0.2 56.52 0.47 Z"
