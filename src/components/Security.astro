---
// Security section — 2-column layout with permission & guarantee lists
---

<section
  id="security"
  class="min-h-screen flex flex-col justify-center py-16 md:py-20 lg:py-24 px-4 md:px-6"
  aria-labelledby="security-heading"
>
  <div
    class="max-w-[1200px] mx-auto grid grid-cols-1 md:grid-cols-2 gap-12 lg:gap-16"
  >
    <!-- Left column -->
    <div class="animate-on-scroll">
      <p
        class="text-xs uppercase tracking-[0.1em] font-semibold mb-4 text-accent-hive"
      >
        Security First
      </p>
      <h2
        id="security-heading"
        class="text-[2rem] md:text-[2.5rem] font-bold text-white mb-6"
      >
        Your keys never leave MetaMask
      </h2>
      <p class="text-base text-text-secondary leading-relaxed max-w-[480px]">
        Hive Wallet Snap operates under the principle of least privilege.
        Every permission is scoped to the minimum required, and no private keys
        are stored in memory or exposed to the client.
      </p>
    </div>

    <!-- Right column — two groups -->
    <div class="flex flex-col gap-8">
      <!-- Group 1: Required Permissions — terminal-like block -->
      <div class="animate-on-scroll">
        <h3
          class="text-sm uppercase tracking-[0.08em] font-semibold text-accent-hive mb-4"
        >
          Required Permissions
        </h3>
        <div
          class="animate-slide-left rounded-xl border overflow-hidden bg-bg-code"
          style="border-color: var(--border-subtle);"
        >
          <div
            class="flex items-center px-4 py-3 border-b bg-bg-elevated"
            style="border-color: var(--border-subtle);"
          >
            <span class="font-mono text-xs text-text-muted" aria-hidden="true">Permissions</span>
          </div>
          <div class="p-5 font-mono text-sm leading-loose space-y-3 overflow-x-auto">
            <!-- Permission 1 — snap_getBip44Entropy -->
            <div class="animate-slide-left">
              <span style="color: var(--color-text-subtle);">$</span>
              <span class="text-accent-hive ml-2">snap_getBip44Entropy</span>
              <span class="block pl-4" style="color: var(--color-text-subtle);">// For deriving Hive keys from MetaMask seed phrase</span>
            </div>
            <!-- Permission 2 — endowment:rpc -->
            <div class="animate-slide-left" style="transition-delay: 60ms;">
              <span style="color: var(--color-text-subtle);">$</span>
              <span class="text-accent-hive ml-2">endowment:rpc</span>
              <span class="block pl-4" style="color: var(--color-text-subtle);">// For Snap communication with dApps</span>
            </div>
            <!-- Permission 3 — snap_dialog -->
            <div class="animate-slide-left" style="transition-delay: 120ms;">
              <span style="color: var(--color-text-subtle);">$</span>
              <span class="text-accent-hive ml-2">snap_dialog</span>
              <span class="block pl-4" style="color: var(--color-text-subtle);">// For user confirmation when signing transactions or encrypting/decrypting buffer</span>
            </div>
            <!-- Permission 4 — endowment:webassembly -->
            <div class="animate-slide-left" style="transition-delay: 180ms;">
              <span style="color: var(--color-text-subtle);">$</span>
              <span class="text-accent-hive ml-2">endowment:webassembly</span>
              <span class="block pl-4" style="color: var(--color-text-subtle);">// For WebAssembly support in Hive libraries: Wax and Beekeeper</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Group 2: Security Guarantees — simple list -->
      <div class="animate-on-scroll">
        <h3
          class="text-sm uppercase tracking-[0.08em] font-semibold text-accent-hive mb-4"
        >
          Security Guarantees
        </h3>
        <ul class="flex flex-col gap-4" role="list">
          <li
            class="animate-slide-left flex items-baseline gap-3"
            style="transition-delay: 240ms;"
          >
            <span class="text-accent-hive shrink-0" aria-hidden="true">&#10003;</span>
            <p class="text-sm" style="color: var(--color-text-subtle);">
              Keys are derived only when needed and immediately cleared from memory after usage
            </p>
          </li>
          <li
            class="animate-slide-left flex items-baseline gap-3"
            style="transition-delay: 300ms;"
          >
            <span class="text-accent-hive shrink-0" aria-hidden="true">&#10003;</span>
            <p class="text-sm" style="color: var(--color-text-subtle);">
              No network requests are made
            </p>
          </li>
          <li
            class="animate-slide-left flex items-baseline gap-3"
            style="transition-delay: 360ms;"
          >
            <span class="text-accent-hive shrink-0" aria-hidden="true">&#10003;</span>
            <p class="text-sm" style="color: var(--color-text-subtle);">
              Input validation is performed on all transaction data
            </p>
          </li>
          <li
            class="animate-slide-left flex items-baseline gap-3"
            style="transition-delay: 420ms;"
          >
            <span class="text-accent-hive shrink-0" aria-hidden="true">&#10003;</span>
            <p class="text-sm" style="color: var(--color-text-subtle);">
              No sensitive data is stored in browser storage
            </p>
          </li>
        </ul>
      </div>
    </div>
  </div>
</section>
